-- Skin Changer
local skinBtn = Instance.new("TextButton")
skinBtn.Size = UDim2.new(0.85, 0, 0, 55)
skinBtn.Position = UDim2.new(0.075, 0, 0.46, 0)
skinBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
skinBtn.Text = "Random Skin"
