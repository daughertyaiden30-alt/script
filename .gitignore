-- EU Red | Delta Fixed + Combined (No Key)

print("✅ Loading EU Red...")

local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "EURed"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")  -- Better for Delta

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 420, 0, 580)
frame.Position = UDim2.new(0.5, -210, 0.5, -290)
frame.BackgroundColor3 = Color3.fromRGB(25, 0, 0)
frame.BorderSizePixel = 0
frame.Parent = gui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 60)
title.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
title.Text = "EU Red | Rivals"
title.TextColor3 = Color3.new(1, 1, 1)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = frame

-- Fly Button
local flyBtn = Instance.new("TextButton")
flyBtn.Size = UDim2.new(0.85, 0, 0, 55)
flyBtn.Position = UDim2.new(0.075, 0, 0.18, 0)
flyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
flyBtn.Text = "Toggle Fly"
flyBtn.TextColor3 = Color3.new(1,1,1)
flyBtn.TextScaled = true
flyBtn.Parent = frame

flyBtn.MouseButton1Click:Connect(function()
    print("🟥 Fly Toggled - Add real fly code here")
end)

-- Unlock All
local unlockBtn = Instance.new("TextButton")
unlockBtn.Size = UDim2.new(0.85, 0, 0, 55)
unlockBtn.Position = UDim2.new(0.075, 0, 0.32, 0)
